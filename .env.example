# Generator zapytań — zmienne środowiskowe (NIE commitować wypełnionych wartości)

# Port serwera (default 8080)
PORT=8080

# Airtable (brak klucza => tryb mock z data/mock-artists.json)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=app5NIUbshNL31ylr
AIRTABLE_TABLE=Cennik 2026

# Cache katalogu artystów w ms (default 10 min)
CACHE_TTL_MS=600000

# Katalog cache zdjęć na dysku
PHOTO_CACHE_DIR=./photo-cache

# Webhook n8n przyjmujący zapytania (brak => zapytania tylko logowane)
# prod (sieć wewnętrzna docker): http://root-n8n-1:5678/webhook/zapytania-app
N8N_INQUIRY_WEBHOOK_URL=

# Wspólny sekret app -> n8n (wygeneruj: openssl rand -hex 24); ta sama wartość w env n8n
INQUIRY_SHARED_TOKEN=

# Wymuś tryb mock mimo klucza Airtable
MOCK_DATA=
